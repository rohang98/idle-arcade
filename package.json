{
  "name": "idle-arcade",
  "version": "0.2.2",
  "description": "Terminal games that auto-launch when Claude Code is idle",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "idle-arcade": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "postinstall": "echo 'Run idle-arcade setup to configure hooks' 2>/dev/null || true",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "terminal",
    "games",
    "snake",
    "claude",
    "idle",
    "ghostty"
  ],
  "author": "Rohan Gupta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rohang98/idle-arcade.git"
  },
  "bugs": {
    "url": "https://github.com/rohang98/idle-arcade/issues"
  },
  "homepage": "https://github.com/rohang98/idle-arcade#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "typescript-eslint": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.3.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  }
}
