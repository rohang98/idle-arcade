{
  "name": "idle-arcade",
  "version": "0.2.3",
  "description": "Terminal games that auto-launch when Claude Code is idle",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "idle-arcade": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "postinstall": "echo 'Run idle-arcade setup to configure hooks' 2>/dev/null || true",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "terminal",
    "games",
    "snake",
    "claude",
    "idle",
    "ghostty"
  ],
  "author": "Rohan Gupta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rohang98/idle-arcade.git"
  },
  "bugs": {
    "url": "https://github.com/rohang98/idle-arcade/issues"
  },
  "homepage": "https://github.com/rohang98/idle-arcade#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  }
}
